{
  "agents": {
    "defaults": {
      "model": {
        "primary": "amazon-bedrock/anthropic.claude-sonnet-4-6"
      }
    }
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "loopback",
    "auth": {
      "mode": "token"
    }
  },
  "providers": {
    "anthropic": {
      "type": "bedrock",
      "region": "us-east-1"
    }
  }
}
