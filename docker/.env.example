# Gateway auth token — generate with: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=REPLACE_ME_WITH_STRONG_TOKEN

# Model — Bedrock (default) or Anthropic API
OPENCLAW_MODEL=amazon-bedrock/us.anthropic.claude-sonnet-4-20250514-v1:0

# Option A: AWS Bedrock
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Option B: Anthropic API key (comment out AWS vars above)
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: host directory to mount as agent workspace
# HOST_WORKSPACE=~/Projects
